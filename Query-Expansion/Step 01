### The "Sub-Question" Logic Flow
In this pattern, we don't just break the question down; we use a loop to answer each piece and then synthesize the final result.
```python
from langchain_openai import ChatOpenAI
from langchain_core.prompts import ChatPromptTemplate
from langchain_core.output_parsers import StrOutputParser

llm = ChatOpenAI(model="gpt-4", temperature=0)

# --- STEP 1: DECOMPOSITION ---
# Break the complex query into 3 specific sub-questions
decompose_prompt = ChatPromptTemplate.from_template("""
Break this complex query into 3 distinct sub-questions that can be 
answered independently to provide a full comparison:
Query: {query}
""")

decompose_chain = decompose_prompt | llm | StrOutputParser()

# --- STEP 2: EXPANSION (Nested) ---
# For each sub-query, we expand it to get better retrieval
expand_prompt = ChatPromptTemplate.from_template("""
Provide 3 synonyms or alternative versions of this question to 
improve document retrieval:
Question: {sub_query}
""")

expand_chain = expand_prompt | llm | StrOutputParser()

# --- STEP 3: EXECUTION ---
complex_task = "Compare Oracle DB partitioning strategies with Spring Batch parallel processing for 1M+ records."

# 1. Get sub-questions
sub_questions = decompose_chain.invoke({"query": complex_task}).split("\n")

# 2. Expand and Search (Pseudo-code for the loop)
all_results = []
for sq in sub_questions:
    if sq.strip():
        # Expand the sub-question for better vector search
        variants = expand_chain.invoke({"sub_query": sq})
        # doc_results = vectorstore.similarity_search(variants)
        # all_results.append(doc_results)
        print(f"Sub-question: {sq}\nVariants:\n{variants}\n{'-'*20}")

